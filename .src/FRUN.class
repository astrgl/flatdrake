Public Sub Form_Open()
'FMAIN.Enabled = False 
FMAIN.FMAINLOCK
' If FMAIN.Spinner1.Visible = True Then
'   FMAIN.Spinner1.Stop 
'   FMAIN.Spinner1.Visible = False
' Endif
TXTSTEP.Text = "Please wait..."
'FMAIN.Enabled = False
FMAIN.BTNCOMMAND.Enabled = True
BTNSTOP.Picture = Picture.Load(FMAIN.$PATHICONS & "stop" & FMain.$THEMESSUFFIX)
If FOK.Visible = True Then
    FRUN.Close
Endif
