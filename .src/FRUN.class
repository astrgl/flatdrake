End
Public Sub Form_KeyPress()
  If Key.Code = Key.Space And BTNSTOP.HasFocus Then
     BTNSTOP_Click
  Endif
End


Public Sub form_Close()
  'FMAIN.Enabled = True
  FMAIN.FMAINUNLOCK
End
Public Sub BTNSTOP_Click()

  FMAIN.BTNSTOP_Click
  Wait 0.2
  Me.Close

End
